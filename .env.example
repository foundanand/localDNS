# Cloudflare API token — needs Zone:DNS:Edit permission
# Get one at: dash.cloudflare.com -> My Profile -> API Tokens
CF_API_TOKEN=your_cloudflare_api_token_here

# Optional — used by Let's Encrypt for cert expiry notifications
CF_EMAIL=you@example.com

# Required on macOS and Windows when running dynamoip inside Docker.
# Set this to your machine's LAN IP (e.g. 192.168.1.42).
# Not needed on Linux — dynamoip auto-detects it via os.networkInterfaces().
# LAN_IP=
